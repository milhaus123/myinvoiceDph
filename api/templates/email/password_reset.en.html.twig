{% extends '_layout.html.twig' %}

{% block content %}
<h1 style="margin:0 0 16px;font-size:22px;font-weight:600;color:#18181b;">Password reset</h1>

<p style="margin:0 0 16px;">Hello{% if name %} {{ name }}{% endif %},</p>

<p style="margin:0 0 16px;">We received a request to reset the password for your <strong>MyInvoice.cz</strong> account.
Click the button below to set a new password:</p>

<p style="margin:24px 0;text-align:center;">
  <a href="{{ resetLink }}" style="display:inline-block;background:#3B2D83;color:#ffffff;text-decoration:none;font-weight:600;padding:12px 28px;border-radius:6px;font-size:15px;">
    Set new password
  </a>
</p>

<p style="margin:0 0 8px;font-size:13px;color:#71717a;">
  The link is valid for <strong>{{ expiresIn|default('60 minutes') }}</strong> and can be used only once.
</p>

<p style="margin:0 0 8px;font-size:13px;color:#71717a;">
  If the button doesn't work, copy this URL into your browser:
</p>

<p style="margin:0;font-size:12px;color:#52525b;word-break:break-all;background:#f4f4f5;padding:10px;border-radius:6px;font-family:monospace;">
  {{ resetLink }}
</p>

<p style="margin:24px 0 0;font-size:13px;color:#71717a;">
  <strong>If you did not request a password reset</strong>, please ignore this email. Your password will remain unchanged.
</p>
{% endblock %}
