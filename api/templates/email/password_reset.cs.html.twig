{% extends '_layout.html.twig' %}

{% block content %}
<h1 style="margin:0 0 16px;font-size:22px;font-weight:600;color:#18181b;">Obnova hesla</h1>

<p style="margin:0 0 16px;">Dobrý den{% if name %} {{ name }}{% endif %},</p>

<p style="margin:0 0 16px;">obdrželi jsme žádost o obnovu hesla k Vašemu účtu v <strong>MyInvoice.cz</strong>.
Pro nastavení nového hesla klikněte na tlačítko níže:</p>

<p style="margin:24px 0;text-align:center;">
  <a href="{{ resetLink }}" style="display:inline-block;background:#3B2D83;color:#ffffff;text-decoration:none;font-weight:600;padding:12px 28px;border-radius:6px;font-size:15px;">
    Nastavit nové heslo
  </a>
</p>

<p style="margin:0 0 8px;font-size:13px;color:#71717a;">
  Odkaz je platný <strong>{{ expiresIn|default('60 minut') }}</strong> a lze ho použít jen jednou.
</p>

<p style="margin:0 0 8px;font-size:13px;color:#71717a;">
  Pokud tlačítko nefunguje, zkopírujte tuto adresu do prohlížeče:
</p>

<p style="margin:0;font-size:12px;color:#52525b;word-break:break-all;background:#f4f4f5;padding:10px;border-radius:6px;font-family:monospace;">
  {{ resetLink }}
</p>

<p style="margin:24px 0 0;font-size:13px;color:#71717a;">
  <strong>Pokud jste o obnovu hesla nežádali</strong>, tento email ignorujte. Vaše heslo zůstane beze změny.
</p>
{% endblock %}
